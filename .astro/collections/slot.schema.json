            },
            "paylines": {
              "type": "number"
            },
            "minBet": {
              "type": "string"
            },
            "maxBet": {
              "type": "string"
            },
            "hitFrequency": {
              "type": "string"
            },
            "bonusFeatures": {
              "type": "string"
            },
            "releaseYear": {
              "type": "number"
            },
            "provider": {
              "type": "string"
            }
          },
