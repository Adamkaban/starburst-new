---
import SEOHead from "../components/seo/SEOHead.astro";
import SiteHeader from "../components/common/SiteHeader.astro";
import SiteFooter from "../components/common/SiteFooter.astro";
import config from "../../site.config";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  schema?: object | object[] | null;
  ogType?: "website" | "article";
}

const {
  title,
  description,
  ogImage,
  ogImageAlt,
  noindex = false,
  schema,
  ogType,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={config.seo.lang}>
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      noindex={noindex}
      schema={schema}
      ogType={ogType}
    />
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text)]">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded">
      Skip to main content
    </a>
    <SiteHeader />
    <slot />
    <SiteFooter />
  </body>
</html>
