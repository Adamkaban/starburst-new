---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbs } from "../components/seo/SchemaBuilder";

const meta = {
  title:      "Privacy Policy – Starburst Slots ZA",
  description: "Privacy policy for starburstslots.co.za. How we collect, use and protect personal data. Affiliate link disclosure and cookie usage.",
  canonical:  "https://starburstslots.co.za/privacy-policy/",
  noindex:    true,
  ogImage:    "/images/og/og-default.webp",
  ogImageAlt: "Starburst Slots ZA privacy policy",
};

const schema = buildBreadcrumbs([
  { name: "Home", path: "/" },
  { name: "Privacy Policy", path: "/privacy-policy/" },
]);
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  noindex={meta.noindex}
  schema={schema}
>
  <main id="main-content" class="container section">
    <div style="max-width: var(--content-max); margin-inline: auto;">

      <h1 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; margin-bottom: var(--spacing-md); color: var(--color-text);">
        Privacy Policy
      </h1>
      <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-bottom: var(--spacing-2xl);">
        Last updated: 23 May 2026
      </p>

      <div style="display: flex; flex-direction: column; gap: var(--spacing-2xl); color: var(--color-text-muted); line-height: 1.8;">

        <section>
          <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-md); color: var(--color-text);">1. Who We Are</h2>
          <p>
            This privacy policy applies to starburstslots.co.za, an independent casino games review site operated by Johan van der Merwe.
            We are not affiliated with NetEnt, any casino operator, or the National Lottery.
          </p>
        </section>

        <section>
          <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-md); color: var(--color-text);">2. Data We Collect</h2>
          <p>
            This site is a static website. We do not operate user accounts, process payments, or store personal data directly.
            We use standard web analytics to understand aggregate visitor behaviour (page views, device types, geographic regions).
            Analytics data does not identify individual visitors.
          </p>
        </section>

        <section>
          <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-md); color: var(--color-text);">3. Affiliate Links</h2>
          <p>
            This site contains affiliate links to third-party casino operators. When you click an affiliate link and create an account or make a deposit,
            we may receive a commission from the casino operator. This does not affect the price you pay or the terms offered to you.
            All affiliate relationships are disclosed on the relevant pages.
          </p>
        </section>

        <section>
          <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-md); color: var(--color-text);">4. Cookies</h2>
          <p>
            This site uses minimal cookies for analytics purposes only. No marketing, tracking, or third-party advertising cookies are set.
            You can disable cookies in your browser settings without affecting your ability to use this site.
          </p>
        </section>

        <section>
          <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-md); color: var(--color-text);">5. Third-Party Sites</h2>
          <p>
            Links to casino operators and the National Responsible Gambling Programme (NRGP) lead to third-party websites with their own privacy policies.
            We are not responsible for the data practices of linked sites. Review each site's privacy policy before providing personal information.
          </p>
        </section>

        <section>
          <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-md); color: var(--color-text);">6. Your Rights</h2>
          <p>
            Under South African POPIA (Protection of Personal Information Act), you have the right to access, correct, and request deletion of personal data held about you.
            Since we do not store personal data directly, these rights apply primarily to our analytics provider.
            Contact us at the email address below with any requests.
          </p>
        </section>

        <section>
          <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-md); color: var(--color-text);">7. Contact</h2>
          <p>
            For privacy-related enquiries: liotar2031@gmail.com
          </p>
        </section>

      </div>
    </div>
  </main>
</BaseLayout>
