---
import config from "../../../site.config";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  schema?: object | object[] | null;
  ogType?: "website" | "article";
}

const {
  title,
  description = config.seo.defaultDescription,
  ogImage = config.seo.ogImage,
  ogImageAlt = config.seo.ogImageAlt,
  noindex = false,
  schema = null,
  ogType = "article",
} = Astro.props;

const fullTitle = config.seo.titleTemplate.replace("%s", title);
const robots = noindex ? "noindex, nofollow" : "index, follow";
const canonical = `${config.seo.siteUrl}${Astro.url.pathname}`;
const ogImageUrl = `${config.seo.siteUrl}${ogImage}`;

const schemas = schema === null
  ? []
  : Array.isArray(schema)
  ? schema
  : [schema];
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<meta name="author" content={config.brand.author} />
<meta name="geo.region" content={config.seo.geo} />
<link rel="canonical" href={canonical} />

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/webp" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={config.seo.locale} />
<meta property="og:site_name" content={config.brand.name} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

{schemas.map((s) => (
  <script type="application/ld+json" set:html={JSON.stringify(s)} />
))}
