---
interface Props {
  providerLogo: string;
  providerName?: string;
  description: string;
  stats: {
    founded: number;
    gamesReleased: string;
    licensedMarkets: string;
    averageRtp: string;
  };
}

const { providerLogo, providerName = "NetEnt", description, stats } = Astro.props;
---

<section class="py-12 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl font-bold mb-8">About {providerName} — Starburst's Developer</h2>

    <div class="flex flex-col md:flex-row gap-8 items-start">
      <div class="flex-shrink-0">
        <img
          src={providerLogo}
          width={120}
          height={60}
          alt={`${providerName} logo`}
          loading="lazy"
          class="object-contain"
        />
      </div>

      <div>
        <p class="text-gray-700 mb-6">{description}</p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-[#7c3aed]">{stats.founded}</p>
            <p class="text-sm text-gray-500">Founded</p>
          </div>

          <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-[#7c3aed]">{stats.gamesReleased}</p>
            <p class="text-sm text-gray-500">Games Released</p>
          </div>

          <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-[#7c3aed]">{stats.licensedMarkets}</p>
            <p class="text-sm text-gray-500">Licensed Markets</p>
          </div>

          <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-[#7c3aed]">{stats.averageRtp}</p>
            <p class="text-sm text-gray-500">Avg. RTP</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
