---
import { Check, X } from "@lucide/astro";
import CTAButton from "../common/CTAButton.astro";
import RatingStars from "../common/RatingStars.astro";

interface Props {
  pros: string[];
  cons: string[];
  rating: number;
  ratingMax?: number;
  affiliateUrl: string;
}

const { pros, cons, rating, ratingMax = 5, affiliateUrl } = Astro.props;
---

<section class="py-12 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl font-bold mb-6">Starburst Pros &amp; Cons</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">

      <!-- Pros column -->
      <div>
        <h3 class="text-lg font-semibold text-green-700 mb-4">Pros</h3>
        <ul class="space-y-3 list-none p-0">
          {pros.map((pro) => (
            <li class="flex items-start gap-2">
              <Check size={18} color="#16a34a" aria-hidden="true" class="flex-shrink-0 mt-0.5" />
              <span>{pro}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Cons column -->
      <div>
        <h3 class="text-lg font-semibold text-red-700 mb-4">Cons</h3>
        <ul class="space-y-3 list-none p-0">
          {cons.map((con) => (
            <li class="flex items-start gap-2">
              <X size={18} color="#dc2626" aria-hidden="true" class="flex-shrink-0 mt-0.5" />
              <span>{con}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Rating + CTA row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 border-t border-gray-200">
      <div class="flex items-center gap-3">
        <RatingStars rating={rating} max={ratingMax} />
        <span class="text-lg font-bold">{rating}/{ratingMax}</span>
      </div>
      <CTAButton
        href={affiliateUrl}
        variant="primary"
        size="lg"
        text="Play Starburst Now"
      />
    </div>

  </div>
</section>
