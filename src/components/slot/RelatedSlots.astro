---
import CTAButton from "../common/CTAButton.astro";

interface RelatedSlot {
  name: string;
  rtp: string;
  volatility: string;
  image?: string;
  url?: string;
}

interface Props {
  slots: RelatedSlot[];
  affiliateUrl: string;
}

const { slots, affiliateUrl } = Astro.props;
---

<section class="py-12">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl font-bold mb-6">More Slots Like Starburst</h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {slots.map((slot) => {
        const slotHref =
          !slot.url || slot.url === "/" || slot.url === ""
            ? affiliateUrl
            : slot.url;

        return (
          <div class="bg-white border border-gray-200 rounded-lg p-4 flex flex-col gap-3">

            {slot.image ? (
              <img
                src={slot.image}
                width={200}
                height={150}
                alt={`${slot.name} slot`}
                loading="lazy"
                class="w-full rounded"
              />
            ) : (
              <div class="bg-gray-100 rounded h-32 flex items-center justify-center">
                <span class="text-gray-400 text-sm">{slot.name}</span>
              </div>
            )}

            <h3 class="font-semibold text-base">{slot.name}</h3>

            <div class="flex gap-2 flex-wrap">
              <span class="text-xs bg-[#f5f3ff] text-[#7c3aed] px-2 py-1 rounded font-medium">
                RTP: {slot.rtp}
              </span>
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
                {slot.volatility}
              </span>
            </div>

            <CTAButton
              href={slotHref}
              variant="outline"
              size="sm"
              text="Play Now"
            />

          </div>
        );
      })}
    </div>

  </div>
</section>
