---
import config from '../../../site.config';
import { AFFILIATE_URL } from '../../data/casinos';
import Badge from '../ui/Badge.astro';
---

<section
  style="background-color: var(--color-bg); background-image: radial-gradient(circle, var(--color-border) 1px, transparent 1px); background-size: 28px 28px; width: 100%; min-height: 60vh; display: flex; align-items: center;"
>
  <div class="container" style="text-align: center; padding-block: var(--spacing-2xl);">

    <div style="margin-bottom: var(--spacing-lg);">
      <Badge text="NetEnt · 5×3 Grid · RTP 96.09% · Low Volatility" />
    </div>

    <div style="margin-bottom: var(--spacing-lg);">
      <img
        src="/images/slots/starburst.webp"
        width="800"
        height="450"
        alt="Starburst slot game by NetEnt — expanding wilds on a 5×3 gem-themed reel grid"
        loading="eager"
        fetchpriority="high"
        style="max-width: min(100%, 560px); height: auto; border-radius: var(--radius-md); display: block; margin-inline: auto;"
      />
    </div>

    <h1 style="font-family: var(--font-heading); font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 700; color: var(--color-text); line-height: 1.2; margin-bottom: var(--spacing-md);">
      Starburst Slot — Play Demo Free, Full Review &amp; Best South African Casinos
    </h1>

    <p style="font-size: 1.125rem; font-weight: 500; color: var(--color-accent); margin-bottom: var(--spacing-md); letter-spacing: 0.02em;">
      Free Demo · Full Review · RTP, Strategy &amp; Best SA Casinos
    </p>

    <p style="max-width: 58ch; margin-inline: auto; margin-bottom: var(--spacing-xl); color: var(--color-text-muted); font-size: 1rem; line-height: 1.7;">
      {config.seo.defaultDescription}
    </p>

    <div style="display: flex; flex-wrap: wrap; gap: var(--spacing-md); justify-content: center; margin-bottom: var(--spacing-lg);">
      <a
        href="/demo/"
        style="background-color: var(--color-cta); color: #0f0f13; font-weight: 700; padding: 0.75rem 2rem; font-size: 1.125rem; border-radius: var(--radius-full); text-decoration: none; display: inline-block;"
      >
        Play Demo Free
      </a>

      <a
        href={AFFILIATE_URL}
        rel="nofollow noopener noreferrer"
        target="_blank"
        style="background-color: var(--color-primary); color: #ffffff; font-weight: 600; padding: 0.75rem 2rem; font-size: 1.125rem; border-radius: var(--radius-full); text-decoration: none; display: inline-block;"
      >
        Play for Real
      </a>
    </div>

    <p style="font-size: 0.75rem; color: var(--color-text-muted);">
      18+ | Gambling involves risk. Play responsibly.
    </p>

  </div>
</section>
