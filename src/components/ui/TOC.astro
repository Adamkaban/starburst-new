---
interface TOCItem {
  id: string;
  label: string;
}

interface Props {
  items: TOCItem[];
}

const { items } = Astro.props;
---

<details class="rounded-md mb-6" style="background-color: var(--color-bg-elevated); border: 1px solid var(--color-border); padding: var(--spacing-md);">
  <summary
    class="cursor-pointer text-sm font-medium select-none"
    style="color: var(--color-text-muted);"
  >
    Contents
  </summary>
  <nav aria-label="Table of contents" class="mt-3">
    <ol class="list-decimal list-inside space-y-1">
      {items.map((item) => (
        <li class="text-sm">
          <a
            href={`#${item.id}`}
            class="no-underline"
            style="color: var(--color-accent);"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ol>
  </nav>
</details>
