---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'accent';
  size?: 'sm' | 'md' | 'lg';
  rel?: string;
  target?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  rel,
  target,
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'py-1.5 px-4 text-sm',
  md: 'py-2 px-6 text-base',
  lg: 'py-3 px-8 text-lg',
};

const variantClasses: Record<string, string> = {
  primary:  'font-bold',
  outline:  'border bg-transparent font-medium',
  accent:   'text-white font-medium',
};
---

<a
  href={href}
  rel={rel}
  target={target}
  class={`inline-flex items-center justify-center rounded-full font-sans no-underline ${sizeClasses[size]} ${variantClasses[variant]}`}
  style={
    variant === 'primary'
      ? 'background-color: var(--color-cta); color: #0f0f13; border-radius: var(--radius-full);'
      : variant === 'outline'
      ? 'border: 1px solid var(--color-primary); color: var(--color-accent); background: transparent; border-radius: var(--radius-full);'
      : 'background-color: var(--color-primary); color: #ffffff; border-radius: var(--radius-full);'
  }
>
  <slot />
</a>
