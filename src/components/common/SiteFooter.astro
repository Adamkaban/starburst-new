---
import config from "../../../site.config";
---

<footer style="background-color: var(--color-bg-elevated); border-top: 1px solid var(--color-border);">

  <!-- TOP: Logo + Explore nav -->
  <div class="container py-10">
    <div class="flex flex-col gap-8 md:flex-row md:justify-between">

      <!-- Left: Logo + tagline -->
      <div class="flex flex-col gap-3">
        <a href="/" class="inline-flex items-center gap-2 no-underline">
          <img
            src={config.brand.logo}
            width="120"
            height="40"
            alt={config.brand.name}
            loading="lazy"
            class="h-8 w-auto"
          />
        </a>
        <p class="text-sm" style="color: var(--color-text-muted);">{config.brand.name}</p>
      </div>

      <!-- Right: Explore nav -->
      <nav aria-label="Explore navigation">
        <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-muted);">Explore</p>
        <ul class="grid grid-cols-2 gap-x-8 gap-y-1.5" style="list-style: none; padding-left: 0;">
          <li><a href="/" class="text-sm no-underline" style="color: var(--color-text);">Home</a></li>
          <li><a href="/review/" class="text-sm no-underline" style="color: var(--color-text);">Review</a></li>
          <li><a href="/demo/" class="text-sm no-underline" style="color: var(--color-text);">Demo</a></li>
          <li><a href="/features/" class="text-sm no-underline" style="color: var(--color-text);">Features</a></li>
          <li><a href="/how-to-play/" class="text-sm no-underline" style="color: var(--color-text);">How to Play</a></li>
          <li><a href="/rtp-volatility/" class="text-sm no-underline" style="color: var(--color-text);">RTP &amp; Volatility</a></li>
          <li><a href="/bonuses/" class="text-sm no-underline" style="color: var(--color-text);">Bonuses</a></li>
          <li><a href="/strategy/" class="text-sm no-underline" style="color: var(--color-text);">Strategy</a></li>
          <li><a href="/mobile/" class="text-sm no-underline" style="color: var(--color-text);">Mobile</a></li>
          <li><a href="/faq/" class="text-sm no-underline" style="color: var(--color-text);">FAQ</a></li>
          <li><a href="/casinos/" class="text-sm no-underline" style="color: var(--color-text);">Casinos</a></li>
          <li><a href="/about/" class="text-sm no-underline" style="color: var(--color-text);">About</a></li>
          <li><a href="/responsible-gambling/" class="text-sm no-underline" style="color: var(--color-text);">Responsible Gambling</a></li>
        </ul>
      </nav>

    </div>
  </div>

  <!-- MID: Responsible gambling disclaimer -->
  <div class="container py-6" style="border-top: 1px solid var(--color-border);">
    <p class="text-sm mb-2" style="color: var(--color-text-muted);">
      {config.responsible.disclaimer}
      {" "}
      <a
        href={config.responsible.nrgpUrl}
        rel="nofollow noopener noreferrer"
        target="_blank"
        class="no-underline"
        style="color: var(--color-accent);"
      >National Responsible Gambling Programme</a>.
    </p>
    <p class="text-sm" style="color: var(--color-text-muted);">
      Helpline: <strong style="color: var(--color-text);">{config.responsible.helpline}</strong> (free, 24/7)
    </p>
    <p class="text-xs mt-2" style="color: var(--color-text-muted);">
      Starburst™ is a trademark of NetEnt Product Services Ltd / Evolution. This website is not affiliated with, endorsed by or in any way connected with NetEnt or Evolution. All game images and names are used for informational purposes only.
    </p>
  </div>

  <!-- BOTTOM: Legal nav + copyright -->
  <div class="container py-4" style="border-top: 1px solid var(--color-border);">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">

      <nav aria-label="Legal navigation">
        <ul class="flex flex-wrap gap-x-4 gap-y-1" style="list-style: none; padding-left: 0;">
          <li><a href="/about/" class="text-xs no-underline" style="color: var(--color-text-muted);">About</a></li>
          <li><a href="/privacy-policy/" class="text-xs no-underline" style="color: var(--color-text-muted);">Privacy Policy</a></li>
          <li><a href="/terms-of-use/" class="text-xs no-underline" style="color: var(--color-text-muted);">Terms of Use</a></li>
          <li><a href="/responsible-gambling/" class="text-xs no-underline" style="color: var(--color-text-muted);">Responsible Gambling</a></li>
        </ul>
      </nav>

      <p class="text-xs" style="color: var(--color-text-muted);">
        &copy; 2026 Starburst Slots ZA
      </p>

    </div>
  </div>

</footer>
