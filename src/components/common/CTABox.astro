---
import CTAButton from "./CTAButton.astro";

interface Props {
  affiliateUrl: string;
  primaryText?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  affiliateUrl,
  primaryText = "Play Starburst Now",
  secondaryText,
  secondaryHref = affiliateUrl,
} = Astro.props;
---

<div class="bg-[#f5f3ff] rounded-lg p-6 md:p-8 flex flex-col items-center gap-4">
  <CTAButton
    href={affiliateUrl}
    variant="primary"
    size="lg"
    text={primaryText}
  />
  {secondaryText && (
    <CTAButton
      href={secondaryHref}
      variant="outline"
      size="md"
      text={secondaryText}
    />
  )}
  <p class="text-sm text-gray-600 text-center mt-2">
    Gambling involves risk. Play responsibly. 18+ only.
  </p>
</div>
